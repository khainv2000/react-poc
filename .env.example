# Base URL for Axios (ex: http://localhost:8080 or https://api.example.com)
# If omitted, the app defaults to "/api".
VITE_API_BASE_URL=

# Optional: Vite dev proxy target for "/api" (ex: http://localhost:8080)
# If set, Vite will proxy requests from http://localhost:5173/api/* -> target
VITE_DEV_PROXY_TARGET=http://localhost:8080

